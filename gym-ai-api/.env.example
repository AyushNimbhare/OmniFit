# Database URL (SQLite is the default local database)
DATABASE_URL=sqlite:///gym_ai.db

# Google Gemini API Key for live workout analysis and coach insights.
# Leave empty to run the app in simulated fallback mode.
GEMINI_API_KEY=

# OpenRouter API Key for live chat coach chatbot.
# Leave empty to run the chatbot in simulated fallback mode.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
